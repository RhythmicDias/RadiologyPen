{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RadiologyPen",
  "version": "0.1.0",
  "identifier": "com.radiologypen.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RadiologyPen Toolbar",
        "width": 600,
        "height": 140,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "visible": true,
        "url": "/"
      },
      {
        "label": "canvas",
        "title": "RadiologyPen Canvas",
        "decorations": false,
        "fullscreen": true,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": false,
        "url": "/canvas"
      },
      {
        "label": "mirror",
        "title": "RadiologyPen Parent View",
        "decorations": false,
        "fullscreen": true,
        "visible": false,
        "url": "/mirror"
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 600,
        "height": 500,
        "resizable": false,
        "visible": false,
        "url": "/settings"
      },
      {
        "label": "ai-result",
        "title": "AI Analysis Result",
        "width": 400,
        "height": 300,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "url": "/ai-result"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
